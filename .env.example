# Server Configuration
PORT=4000
NODE_ENV=development

# Admin Authentication
ADMIN_PASSWORD=your_secure_admin_password_here
ADMIN_SESSION_SECRET=your_session_secret_here
ADMIN_SESSION_DURATION=3600000

# Google OAuth (for Admin Sign-In)
# NOTE: keep GOOGLE_CLIENT_ID and VITE_GOOGLE_CLIENT_ID in sync for client-side login.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
ALLOWED_ADMIN_EMAILS=admin@lphaskhomes.com,owner@lphaskhomes.com

# CORS Configuration
# For deployment, set this to your site origin, e.g. https://lphask-homes-properties.vercel.app
# For local development, allow both localhost and 127.0.0.1 to avoid browser origin issues.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Firebase Private Key Here\n-----END PRIVATE KEY-----\n"
FIREBASE_COLLECTION=appStore
FIREBASE_DOC_ID=default

# Email Configuration (for password reset)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=LPHASK Homes <noreply@lphaskhomes.com>

# Application URL
APP_URL=http://localhost:3000

# Vite proxy for local development
VITE_API_PROXY_TARGET=http://localhost:4000

# Gemini AI API Key (for chatbot)
# Leave blank if not using the chatbot feature.
GEMINI_API_KEY=your_gemini_api_key_here
