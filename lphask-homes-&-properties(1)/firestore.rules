rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isVerifiedAdmin() {
      // Keep this aligned with VITE_SUPER_ADMIN_EMAILS in the app env.
      // Firestore rules cannot read environment variables directly.
      return request.auth != null
        && request.auth.token.email == "bcorp6493@gmail.com"
        && request.auth.token.email_verified == true;
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    match /config/site {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isVerifiedAdmin());
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
